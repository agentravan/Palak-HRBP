@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Inter:wght@100..900&family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&display=swap');
@import "tailwindcss";

@theme {
  --font-sans: "Inter", ui-sans-serif, system-ui, sans-serif;
  --font-serif: "Playfair Display", serif;
  --font-mono: "JetBrains Mono", monospace;

  --color-gold-50: #fffbeb;
  --color-gold-100: #fef3c7;
  --color-gold-200: #fde68a;
  --color-gold-300: #fcd34d;
  --color-gold-400: #fbbf24;
  --color-gold-500: #f59e0b;
  --color-gold-600: #d97706;
  --color-gold-700: #b45309;
  --color-gold-800: #92400e;
  --color-gold-900: #78350f;

  --color-midnight-50: #f8fafc;
  --color-midnight-100: #f1f5f9;
  --color-midnight-200: #e2e8f0;
  --color-midnight-300: #cbd5e1;
  --color-midnight-400: #94a3b8;
  --color-midnight-500: #64748b;
  --color-midnight-600: #475569;
  --color-midnight-700: #334155;
  --color-midnight-800: #1e293b;
  --color-midnight-900: #0f172a;
  --color-midnight-950: #020617;
}

@layer base {
  body {
    @apply bg-midnight-950 text-midnight-100 font-sans antialiased selection:bg-gold-500/30;
  }

  h1, h2, h3, h4, h5, h6 {
    @apply font-serif tracking-tight text-white font-medium;
  }

  p {
    @apply leading-relaxed text-midnight-300;
  }
}

@layer components {
  .bento-card {
    @apply bg-midnight-900/40 backdrop-blur-sm border border-midnight-800 p-6 rounded-3xl hover:border-gold-700/50 transition-all duration-500 shadow-2xl shadow-black/20;
  }

  .timeline-dot {
    @apply absolute -left-2 w-4 h-4 rounded-full bg-gold-600 ring-4 ring-midnight-950 shadow-lg shadow-gold-900/20;
  }

  .nav-blur {
    @apply fixed top-0 w-full z-50 bg-midnight-950/80 backdrop-blur-md border-b border-midnight-900;
  }
}

/* Print Styles for ATS/PDF export */
@media print {
  @page {
    margin: 1.5cm;
  }

  body {
    background: white !important;
    color: black !important;
    font-size: 11pt;
  }

  h1, h2, h3, .text-white {
    color: black !important;
  }

  p, .text-midnight-300, .text-midnight-400 {
    color: #444 !important;
  }

  .no-print {
    display: none !important;
  }

  .bento-card {
    border: 1px solid #eee !important;
    background: white !important;
    box-shadow: none !important;
    border-radius: 0 !important;
  }

  .timeline-dot {
    ring-color: white !important;
  }

  .bg-midnight-900, .bg-midnight-950 {
    background: transparent !important;
  }
}
