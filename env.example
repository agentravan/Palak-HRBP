@import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600;1,700&family=Inter:wght@100..900&family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&display=swap');
@import "tailwindcss";

@theme {
  --font-sans: "Inter", ui-sans-serif, system-ui, sans-serif;
  --font-serif: "Cormorant Garamond", serif;
  --font-mono: "JetBrains Mono", monospace;

  --color-executive-navy: #0f172a;
  --color-executive-gold: #b45309;
  --color-executive-slate: #f8fafc;
  --color-executive-ink: #1e293b;
}

@layer base {
  body {
    @apply bg-executive-slate text-executive-ink font-sans antialiased;
  }

  h1, h2, h3 {
    @apply font-serif;
  }
}

/* Print Styles for ATS/PDF export */
@media print {
  body {
    background-color: white;
  }
  .no-print {
    display: none;
  }
  .print-only {
    display: block;
  }
}
